# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ── LLM provider ─────────────────────────────────────────────
# "local" (default) = your unsloth-served model via an OpenAI-compatible API
# "anthropic"       = Claude API (needs ANTHROPIC_API_KEY or `ant auth login`)
LLM_PROVIDER=local

# Local LLM (unsloth via vLLM / llama.cpp serve — OpenAI-compatible)
LOCAL_LLM_BASE_URL=http://localhost:8000/v1
LOCAL_LLM_MODEL=unsloth-model
# LOCAL_LLM_API_KEY=

# Anthropic (only if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=

# Where user sessions and uploaded files are stored (default: ./data)
# DATA_DIR=./data

# ── Rate limit (open to everyone; this only caps per-user message volume) ──
# Max agent messages per chat per day (default 50)
# DAILY_MSG_LIMIT=50

# ── Control dashboard (switch the AI model at runtime, no restart) ──
# DASHBOARD_PORT=8787
# Bind address: 127.0.0.1 (default, SSH-tunnel only) or 0.0.0.0 for remote access
# DASHBOARD_HOST=127.0.0.1
# Token to unlock the dashboard. If unset, one is generated and printed at startup.
# DASHBOARD_TOKEN=

# ── Assisted browser form-filling ────────────────────────────
# Set to "off" to disable the browser_* tools (agent then only does cheat sheets).
# ENABLE_BROWSER=on
# Max agent tool-loop steps per turn (browser flows need many; default 40)
# MAX_AGENT_ITERATIONS=40
# Max concurrent browser (form-filling) sessions across all users (default 12)
# MAX_BROWSER_SESSIONS=12
